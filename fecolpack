<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:#fff;color:#1a1a1a;}
header{display:flex;justify-content:space-between;align-items:center;padding:14px 60px;background:#111;position:sticky;top:0;z-index:1000;}
.logo-w{display:flex;align-items:center;gap:10px;}
.logo-icon{width:36px;height:36px;background:#ff4f2b;border-radius:6px;display:flex;align-items:center;justify-content:center;}
.logo-icon svg{width:20px;height:20px;fill:white;}
.logo-text{color:#fff;font-weight:500;font-size:17px;letter-spacing:0.5px;}
.logo-text span{color:#ff4f2b;}
nav{display:flex;align-items:center;gap:28px;}
nav a{color:rgba(255,255,255,0.75);text-decoration:none;font-size:14px;font-weight:400;transition:color 0.2s;}
nav a:hover{color:#fff;}
.nav-cta{background:#ff4f2b;color:#fff !important;padding:8px 18px;border-radius:6px;font-size:14px;}
.hero{position:relative;height:95vh;min-height:560px;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:#111;}
.hero-bg img{width:100%;height:100%;object-fit:cover;opacity:0.45;}
.hero-content{position:relative;z-index:2;padding:20px;}
.hero-badge{display:inline-block;background:rgba(255,79,43,0.2);color:#ff7055;border:0.5px solid rgba(255,79,43,0.4);padding:5px 16px;border-radius:20px;font-size:12px;margin-bottom:24px;}
.hero h1{font-size:52px;font-weight:600;color:#fff;max-width:750px;margin:0 auto;line-height:1.15;}
.hero h1 span{color:#ff4f2b;}
.hero p{font-size:18px;color:rgba(255,255,255,0.65);margin:20px auto 36px;max-width:520px;line-height:1.7;}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.btn-primary{background:#ff4f2b;color:#fff;padding:14px 30px;border-radius:8px;text-decoration:none;font-size:15px;font-weight:600;transition:opacity 0.2s;}
.btn-primary:hover{opacity:0.88;}
.btn-secondary{background:rgba(255,255,255,0.1);color:#fff;padding:14px 30px;border-radius:8px;text-decoration:none;font-size:15px;border:0.5px solid rgba(255,255,255,0.25);transition:background 0.2s;}
.btn-secondary:hover{background:rgba(255,255,255,0.18);}
.hero-stats{display:flex;gap:48px;justify-content:center;margin-top:56px;padding-top:40px;border-top:0.5px solid rgba(255,255,255,0.15);}
.stat-n{font-size:30px;font-weight:600;color:#fff;}
.stat-l{font-size:13px;color:rgba(255,255,255,0.5);margin-top:5px;}
.section{padding:72px 60px;max-width:1200px;margin:0 auto;}
.sec-label{font-size:12px;color:#ff4f2b;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:12px;}
.sec-h{font-size:32px;font-weight:600;color:#1a1a1a;}
.sec-sub{font-size:15px;color:#666;margin-top:12px;line-height:1.7;max-width:540px;}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:44px;}
.feat-card{background:#f9f9f9;border:0.5px solid #eee;border-radius:12px;padding:28px;}
.feat-icon{width:44px;height:44px;background:rgba(255,79,43,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;}
.feat-icon svg{width:22px;height:22px;stroke:#ff4f2b;fill:none;stroke-width:2;}
.feat-title{font-size:15px;font-weight:600;color:#1a1a1a;margin-bottom:8px;}
.feat-desc{font-size:13px;color:#666;line-height:1.6;}
.products-wrap{background:#f4f4f4;padding:72px 0;}
.products-inner{max-width:1200px;margin:0 auto;padding:0 60px;}
.prod-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;margin-top:44px;}
.prod-card{background:#fff;border:0.5px solid #e5e5e5;border-radius:12px;overflow:hidden;transition:transform 0.2s,box-shadow 0.2s;}
.prod-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,0.1);}
.prod-img{height:220px;overflow:hidden;background:#f0f0f0;}
.prod-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.3s;}
.prod-card:hover .prod-img img{transform:scale(1.04);}
.prod-info{padding:22px;}
.prod-tag{display:inline-block;background:rgba(255,79,43,0.1);color:#ff4f2b;font-size:11px;padding:3px 10px;border-radius:20px;margin-bottom:10px;}
.prod-name{font-size:16px;font-weight:600;color:#1a1a1a;}
.prod-desc{font-size:13px;color:#666;margin-top:6px;line-height:1.5;}
.testimonials-wrap{padding:72px 60px;max-width:1200px;margin:0 auto;}
.test-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:44px;}
.test-card{background:#fff;border:0.5px solid #e5e5e5;border-radius:12px;padding:28px;}
.stars{color:#ff4f2b;font-size:15px;margin-bottom:14px;}
.test-text{font-size:14px;color:#555;line-height:1.75;font-style:italic;}
.test-author{margin-top:18px;font-size:13px;font-weight:600;color:#1a1a1a;}
.test-role{font-size:12px;color:#888;margin-top:2px;}
.cta-wrap{background:#111;padding:80px 60px;text-align:center;}
.cta-wrap h2{font-size:36px;font-weight:600;color:#fff;max-width:520px;margin:0 auto;}
.cta-wrap p{font-size:15px;color:rgba(255,255,255,0.5);margin:16px auto 36px;max-width:420px;line-height:1.7;}
.contact-wrap{padding:72px 60px;max-width:1200px;margin:0 auto;}
.contact-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-top:44px;}
.contact-card{background:#f9f9f9;border:0.5px solid #eee;border-radius:12px;padding:26px;}
.contact-label{font-size:12px;color:#888;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;}
.contact-val{font-size:15px;font-weight:500;color:#1a1a1a;}
footer{background:#000;padding:28px 60px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
.footer-brand{font-size:14px;color:rgba(255,255,255,0.6);font-weight:500;}
.footer-copy{font-size:13px;color:rgba(255,255,255,0.35);}
.wa-float{position:fixed;bottom:28px;right:28px;background:#25D366;color:#fff;padding:14px 22px;border-radius:50px;text-decoration:none;font-size:15px;font-weight:600;display:flex;align-items:center;gap:8px;box-shadow:0 6px 20px rgba(37,211,102,0.4);z-index:9999;transition:transform 0.2s,box-shadow 0.2s;}
.wa-float:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(37,211,102,0.5);}
.wa-float svg{width:22px;height:22px;fill:#fff;flex-shrink:0;}
.wa-pulse{width:9px;height:9px;background:#fff;border-radius:50%;animation:pulse 1.8s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(0.7);}}
@media(max-width:768px){header{padding:14px 20px;}nav{display:none;}.hero h1{font-size:32px;}.hero-stats{gap:20px;flex-wrap:wrap;}.section,.testimonials-wrap,.contact-wrap{padding:48px 20px;}.products-inner{padding:0 20px;}.cta-wrap{padding:60px 20px;}footer{padding:24px 20px;flex-direction:column;text-align:center;}}
</style>
